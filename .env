# Which sale to load. In production this would normally come from the route
# (e.g. /sale/:saleId) instead of an env var — see src/App.jsx.
VITE_DEFAULT_SALE_ID=SALE123

# URL of the catalog PDF to render (falls back to a lot's catalog_link if omitted)
# VITE_CATALOG_PDF_URL=https://example.com/catalog.pdf

# Geo IP capture is off by default until the get-geo-ip edge function is built.
# Flip to "true" once it's deployed.
VITE_ENABLE_GEO_IP=false

# Optional: third-party IP geolocation endpoint, used only as a fallback if
# get-geo-ip's own call fails. Only relevant once VITE_ENABLE_GEO_IP=true.
VITE_GEO_IP_ENDPOINT=https://ipapi.co/json/
